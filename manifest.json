{
  "manifest_version": 3,
  "name": "SpaceHeyMods",
  "description": "This is an open-source extension with publicly available code that improves SpaceHey and fixes bugs.",
  "author": "https://spacehey.com/tomokokun",
  "homepage_url": "https://tomokuroki.github.io",
  "version": "1.0.3",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "*://*.spacehey.com/*",
    "*://static.spacehey.net/*",
    "*://cdn.spacehey.net/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SpaceHeyMods Settings"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "spaceheymods@tomokokun",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.spacehey.com/*"],
      "js": [
        "scripts/browser-api.js",
        "scripts/features.js",
        "scripts/features/enterToSend.js",
        "scripts/features/friendNotifications.js",
        "scripts/features/messageNotifications.js",
        "scripts/features/blogNotifications.js",
        "scripts/core.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/sounds/Notifications.mp3", "offscreen.html", "offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ]
}