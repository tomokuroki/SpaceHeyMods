{
  "manifest_version": 3,
  "name": "SpaceHeyMods",
  "description": "This is an open-source extension with publicly available code that improves SpaceHey and fixes bugs.",
  "author": "https://spacehey.com/tomokokun",
  "homepage_url": "https://tomokuroki.github.io",
  "version": "1.0.3",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "*://*.spacehey.com/*",
    "*://static.spacehey.net/*",
    "*://cdn.spacehey.net/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SpaceHeyMods Settings"
  },
  "content_scripts": [
    {
      "matches": ["*://*.spacehey.com/*"],
      "js": [
        "scripts/features.js",
        "scripts/features/enterToSend.js",
        "scripts/features/friendNotifications.js",
        "scripts/features/messageNotifications.js",
        "scripts/features/blogNotifications.js",
        "scripts/core.js"
      ],
      "run_at": "document_end"
    }
  ]
}